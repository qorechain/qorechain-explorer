# QoreChain Explorer — environment
# All chain endpoints default to the verified public hosts baked into
# chain-data/*.json; override per deployment only if they move.

# ── Optional endpoint overrides ──
NEXT_PUBLIC_MAINNET_RPC=
NEXT_PUBLIC_MAINNET_REST=
NEXT_PUBLIC_MAINNET_EVM_RPC=
NEXT_PUBLIC_MAINNET_SVM_RPC=
NEXT_PUBLIC_TESTNET_RPC=
NEXT_PUBLIC_TESTNET_REST=
NEXT_PUBLIC_TESTNET_EVM_RPC=
NEXT_PUBLIC_TESTNET_SVM_RPC=

# ── Integrations ──
# WalletConnect v2 project id (cloud.reown.com). NEVER commit a real id;
# the mobile-pairing section stays disabled while unset.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Dashboard origin linked from the header and the Phantom note.
NEXT_PUBLIC_DASHBOARD_ORIGIN=https://dashboard.qorechain.io
